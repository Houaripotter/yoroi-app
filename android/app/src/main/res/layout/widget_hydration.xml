<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EAU"
        android:textColor="#00BCD4"
        android:textSize="8sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <ProgressBar
        android:id="@+id/widget_water_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:progressTint="#00BCD4"
        android:progressBackgroundTint="#1A00BCD4"
        android:max="100"
        android:progress="0" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_water_cups"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_water_goal_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/8"
            android:textColor="#808080"
            android:textSize="14sp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="4dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="verres aujourd'hui"
        android:textColor="#808080"
        android:textSize="9sp" />

</LinearLayout>
