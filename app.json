{
  "expo": {
    "name": "Yoroi",
    "slug": "yoroi",
    "description": "YOROI - Votre compagnon fitness pour le suivi de poids, composition corporelle et entraînements. 100% offline, vos données restent sur votre appareil.",
    "version": "2.3.0",
    "orientation": "portrait",
    "icon": "./assets/logo d'app/yoroi-logo2.png",
    "scheme": "yoroi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo d'app/yoroi-logo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.houari.yoroi",
      "buildNumber": "6",
      "infoPlist": {
        "NSHealthShareUsageDescription": "YOROI lit vos données de poids, composition corporelle, sommeil, pas, fréquence cardiaque et calories pour afficher vos statistiques de progression, calculer vos objectifs personnalisés et suivre votre évolution physique au fil du temps.",
        "NSHealthUpdateUsageDescription": "YOROI enregistre vos pesées quotidiennes, vos séances d'entraînement, vos données d'hydratation et de sommeil pour synchroniser automatiquement vos progrès entre tous vos appareils.",
        "NSSupportsLiveActivities": true,
        "NSCalendarsUsageDescription": "YOROI accède à votre calendrier pour vous rappeler vos séances d'entraînement planifiées.",
        "NSCalendarsFullAccessUsageDescription": "YOROI accède à votre calendrier pour vous rappeler vos séances d'entraînement planifiées.",
        "NSRemindersUsageDescription": "YOROI utilise les rappels pour vos objectifs fitness.",
        "NSRemindersFullAccessUsageDescription": "YOROI crée des rappels pour vos séances d'entraînement planifiées et vos objectifs fitness.",
        "NSFaceIDUsageDescription": "YOROI utilise Face ID pour sécuriser l'accès à votre profil et vos données personnelles.",
        "NSLocationWhenInUseUsageDescription": "YOROI utilise votre position GPS pour enregistrer le tracé et la distance de vos séances de course, vélo et activités en plein air.",
        "NSLocationAlwaysUsageDescription": "YOROI utilise votre position GPS pour enregistrer le tracé et la distance de vos séances de course, vélo et activités en plein air.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "YOROI utilise votre position GPS pour enregistrer le tracé et la distance de vos séances de course, vélo et activités en plein air.",
        "NSMicrophoneUsageDescription": "YOROI peut utiliser le microphone pour enregistrer des notes vocales liées à vos séances d'entraînement.",
        "NSPhotoLibraryAddUsageDescription": "YOROI enregistre vos photos de progression et vos cartes de partage social dans votre photothèque."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealthAndFitness",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotos",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/logo d'app/logo1.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "YOROI a besoin d'accéder à vos photos pour définir votre photo de profil.",
          "cameraPermission": "YOROI a besoin d'accéder à la caméra pour prendre une photo de profil."
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "YOROI lit vos données de poids, composition corporelle, sommeil, pas, fréquence cardiaque et calories pour afficher vos statistiques de progression, calculer vos objectifs personnalisés et suivre votre évolution physique au fil du temps.",
          "NSHealthUpdateUsageDescription": "YOROI enregistre vos pesées quotidiennes, vos séances d'entraînement, vos données d'hydratation et de sommeil pour synchroniser automatiquement vos progrès entre tous vos appareils.",
          "background": true
        }
      ],
      "expo-secure-store",
      [
        "react-native-health-connect",
        {
          "readPermissions": [
            "android.permission.health.READ_STEPS",
            "android.permission.health.READ_WEIGHT",
            "android.permission.health.READ_BODY_FAT",
            "android.permission.health.READ_SLEEP",
            "android.permission.health.READ_HEART_RATE",
            "android.permission.health.READ_HEART_RATE_VARIABILITY",
            "android.permission.health.READ_RESTING_HEART_RATE",
            "android.permission.health.READ_DISTANCE",
            "android.permission.health.READ_TOTAL_CALORIES_BURNED",
            "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
            "android.permission.health.READ_BASAL_METABOLIC_RATE",
            "android.permission.health.READ_HYDRATION",
            "android.permission.health.READ_OXYGEN_SATURATION",
            "android.permission.health.READ_VO2_MAX",
            "android.permission.health.READ_RESPIRATORY_RATE",
            "android.permission.health.READ_BODY_TEMPERATURE",
            "android.permission.health.READ_LEAN_BODY_MASS",
            "android.permission.health.READ_EXERCISE"
          ],
          "writePermissions": [
            "android.permission.health.WRITE_WEIGHT",
            "android.permission.health.WRITE_BODY_FAT",
            "android.permission.health.WRITE_HYDRATION",
            "android.permission.health.WRITE_SLEEP",
            "android.permission.health.WRITE_EXERCISE"
          ]
        }
      ],
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Logo1",
            "ios": "./assets/logo d'app/logo1.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/logo1.png",
              "backgroundColor": "#000000"
            }
          },
          {
            "name": "Yoroi1",
            "ios": "./assets/logo d'app/yoroi-logo1.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo1.png",
              "backgroundColor": "#2563EB"
            }
          },
          {
            "name": "Yoroi2",
            "ios": "./assets/logo d'app/yoroi-logo2.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo2.png",
              "backgroundColor": "#000000"
            }
          },
          {
            "name": "Yoroi3",
            "ios": "./assets/logo d'app/yoroi-logo3.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo3.png",
              "backgroundColor": "#10B981"
            }
          },
          {
            "name": "Yoroi4",
            "ios": "./assets/logo d'app/yoroi-logo4.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo4.png",
              "backgroundColor": "#000000"
            }
          },
          {
            "name": "Yoroi5",
            "ios": "./assets/logo d'app/yoroi-logo5.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo5.png",
              "backgroundColor": "#10B981"
            }
          },
          {
            "name": "Yoroi6",
            "ios": "./assets/logo d'app/yoroi-logo6.png",
            "android": {
              "foregroundImage": "./assets/logo d'app/yoroi-logo6.png",
              "backgroundColor": "#000000"
            }
          }
        ]
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.houari.yoroi",
      "icon": "./assets/images/android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.VIBRATE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_RESTING_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_BASAL_METABOLIC_RATE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.READ_LEAN_BODY_MASS",
        "android.permission.health.READ_HYDRATION",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_VO2_MAX",
        "android.permission.health.READ_RESPIRATORY_RATE",
        "android.permission.health.READ_BODY_TEMPERATURE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.WRITE_WEIGHT",
        "android.permission.health.WRITE_BODY_FAT",
        "android.permission.health.WRITE_HYDRATION",
        "android.permission.health.WRITE_SLEEP",
        "android.permission.health.WRITE_EXERCISE"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a96c06d9-6d8e-4c8a-92b4-a2c38b9a047a"
      }
    },
    "owner": "houari24"
  }
}
